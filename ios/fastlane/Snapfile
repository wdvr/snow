# Snapfile - Fastlane screenshot configuration

# Devices to capture screenshots on (Xcode 26 / iOS 19 simulators)
devices([
  "iPad Pro 13-inch (M5)",
  "iPad Pro 11-inch (M5)"
])

# Languages to capture
languages([
  "en-US"
])

# Xcode scheme to use
scheme("PowderChaser")

# Output directory
output_directory("./screenshots")

# Clear previous screenshots
clear_previous_screenshots(false)

# Override the status bar
override_status_bar(true)

# Don't stop on first error
stop_after_first_error(false)

# Skip opening the HTML summary
skip_open_summary(true)

# Use concurrent simulators for faster execution
concurrent_simulators(false)

# Project file (relative to ios directory)
project("PowderChaser.xcodeproj")

# Test plan (optional - uses default if not specified)
# testplan("ScreenshotTestPlan")
